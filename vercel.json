{
  "routes": [
    { "src": "/api/(.*)", "dest": "/api/$1" },
    { "handle": "filesystem" },
    { "src": "/(.*)", "dest": "/index.html" }
  ],
  "crons": [
    { "path": "/api/send-reminders", "schedule": "0 6 * * *" },
    { "path": "/api/process-pending-sms", "schedule": "*/15 * * * *" },
    { "path": "/api/cleanup-expired", "schedule": "0 2 * * *" }
  ]
}
