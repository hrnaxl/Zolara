{
  "rewrites": [
    {
      "source": "/((?!api/|assets/|_next/|favicon\\.ico|robots\\.txt|sitemap\\.xml|.*\\.js$|.*\\.css$|.*\\.png$|.*\\.jpg$|.*\\.ico$|.*\\.svg$|.*\\.woff$|.*\\.woff2$|.*\\.map$).*)",
      "destination": "/index.html"
    }
  ],
  "crons": [
    { "path": "/api/send-reminders", "schedule": "0 6 * * *" },
    { "path": "/api/process-pending-sms", "schedule": "*/15 * * * *" },
    { "path": "/api/cleanup-expired", "schedule": "0 2 * * *" }
  ]
}
